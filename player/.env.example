# Copy to .env and set the correct value for your environment.
#
# Local development:
#   VITE_BACKEND_URL=http://localhost:4000
#
# Production (Pi build — set this before running `npm run build`):
#   VITE_BACKEND_URL=https://api.clubhub.yourdomain.com
#
# This value is baked into the JS bundle at build time by Vite.
# Changing it requires a rebuild and redeployment of the player dist.
VITE_BACKEND_URL=http://localhost:4000
