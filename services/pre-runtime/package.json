{
  "name": "@clubhub/pre-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clubhub/corpus-schema": "workspace:*",
    "@clubhub/pre-engine": "workspace:*",
    "@clubhub/pre-types": "workspace:*",
    "@clubhub/telemetry-sdk": "workspace:*",
    "@clubhub/constitutional-types": "workspace:*",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
