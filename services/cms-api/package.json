{
  "name": "@clubhub/cms-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "node dist/migrations/runner.js",
    "migrate:dry": "node dist/migrations/runner.js --dry-run",
    "clean": "rm -rf dist",
    "db:migrate": "tsx src/db/migration-runner.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@clubhub/auth-types": "workspace:^",
    "@clubhub/constitutional-types": "workspace:*",
    "@clubhub/corpus-schema": "workspace:*",
    "@clubhub/fnv-checksum": "workspace:*",
    "@clubhub/pre-engine": "workspace:*",
    "@clubhub/pre-types": "workspace:*",
    "@clubhub/telemetry-sdk": "workspace:*",
    "@fastify/cors": "^9.0.0",
    "fastify": "^4.26.0",
    "pg": "^8.21.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
