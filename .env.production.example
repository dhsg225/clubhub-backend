# ClubHub TV — Production environment template
# Copy to .env.production and fill in real values before starting the stack.
# NEVER commit .env.production to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Your server's public domain name (used by Caddy for TLS provisioning)
# Use 'localhost' for LAN-only / no-TLS deployments
DOMAIN=clubhub.example.com

# PostgreSQL password — use a strong random password (min 20 chars)
# Generate: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_strong_password_here

# Random secret for future signed tokens
# Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_random_hex_secret_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# ACME email for Let's Encrypt certificate notifications
CADDY_ACME_EMAIL=ops@example.com
